<Window x:Class="MeirDownloader.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:MeirDownloader.Desktop.Converters"
        Title="מוריד שיעורים - Meir Downloader" Height="768" Width="1200"
        Background="{DynamicResource BackgroundBrush}"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/icon.ico"
        FontFamily="Segoe UI">

    <Window.Resources>
        <converters:DownloadStatusToColorConverter x:Key="StatusToColor"/>
        <converters:DownloadStatusToVisibilityConverter x:Key="StatusToVisibility"/>
        <converters:TextToInitialConverter x:Key="TextToInitial"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- Main Content (Left) -->
        <Grid Grid.Column="0" Margin="30,30,10,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Top Bar -->
                <RowDefinition Height="Auto"/> <!-- Series List (hidden in topic mode) -->
                <RowDefinition Height="*"/>    <!-- Lessons List -->
                <RowDefinition Height="Auto"/> <!-- Status Bar -->
            </Grid.RowDefinitions>

            <!-- Top Bar -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="מוריד שיעורים" Style="{DynamicResource HeaderTextStyle}"/>
                    <TextBlock Text="הורדת שיעורים ממכון מאיר" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="DownloadPathText" 
                               Text="תיקיית הורדה: ..." 
                               VerticalAlignment="Center" 
                               Foreground="{DynamicResource TextSecondaryBrush}" 
                               Margin="0,0,15,0"
                               TextTrimming="CharacterEllipsis" 
                               MaxWidth="300"/>
                    <Button x:Name="ChooseFolderButton" 
                            Content="בחר תיקייה" 
                            Click="ChooseFolderButton_Click"
                            Style="{DynamicResource SecondaryButtonStyle}"/>
                    <Button x:Name="ThemeToggleButton" 
                            Click="ThemeToggle_Click"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Content="🌙" 
                            FontSize="18"
                            Width="40" Height="40"
                            Padding="0"
                            ToolTip="Toggle Dark Mode"
                            Margin="8,0,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Series Selection (visible only in rabbi mode) -->
            <Grid x:Name="SeriesPanel" Grid.Row="1" Margin="0,0,0,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <TextBlock Text="סדרות" Style="{DynamicResource SectionHeaderStyle}"/>
                
                <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Padding="0,0,0,10">
                    <ListBox x:Name="SeriesListBox" 
                             SelectionChanged="SeriesListBox_SelectionChanged"
                             Background="Transparent" 
                             BorderThickness="0"
                             ItemContainerStyle="{DynamicResource SeriesListBoxItemStyle}">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Vertical" Height="130"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="{Binding Name}" 
                                               FontWeight="Bold" 
                                               TextWrapping="Wrap" 
                                               FontSize="14"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <Border Grid.Row="1" 
                                            Background="{DynamicResource AccentBrush}" 
                                            CornerRadius="10" 
                                            Padding="8,2" 
                                            HorizontalAlignment="Left" 
                                            Margin="0,5,0,0">
                                        <TextBlock Text="{Binding Count, StringFormat='{}{0} שיעורים'}" 
                                                   FontSize="11" 
                                                   Foreground="White"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>

                <!-- Series Loading -->
                <StackPanel x:Name="SeriesLoadingBar" Grid.Row="1" Visibility="Collapsed"
                            VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
                    <ProgressBar IsIndeterminate="True" Height="4" Width="150" Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="טוען סדרות..." TextAlignment="Center" Margin="0,8,0,0" Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </Grid>

            <!-- Lessons List -->
            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="שיעורים" Style="{DynamicResource SectionHeaderStyle}" Margin="0"/>
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="DownloadSeriesButton" Content="הורד סדרה" Click="DownloadSeriesButton_Click"
                                Style="{DynamicResource ModernButtonStyle}" Margin="10,0,0,0" IsEnabled="False"/>
                        <Button x:Name="DownloadTopicButton" Content="הורד נושא" Click="DownloadTopicButton_Click"
                                Style="{DynamicResource ModernButtonStyle}" Margin="10,0,0,0" IsEnabled="False"
                                Visibility="Collapsed"/>
                        <Button x:Name="CancelDownloadButton" Content="בטל הורדה" Click="CancelDownloadButton_Click"
                                Style="{DynamicResource ModernButtonStyle}" Background="{DynamicResource ErrorBrush}"
                                Margin="10,0,0,0" IsEnabled="False" Visibility="Collapsed"/>
                        <Button x:Name="OpenDirectoryButton" Content="📂 פתח תיקייה" Click="OpenDirectoryButton_Click"
                                Style="{DynamicResource SecondaryButtonStyle}" Margin="10,0,0,0"
                                IsEnabled="False" Visibility="Collapsed"
                                ToolTip="פתח את תיקיית ההורדה"/>
                    </StackPanel>
                </Grid>

                <!-- Rabbi filter chips (topic mode only) -->
                <Border x:Name="RabbiFilterPanel" Grid.Row="1" Visibility="Collapsed" Margin="0,0,0,10">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <WrapPanel x:Name="RabbiChipsPanel" Orientation="Horizontal"/>
                    </ScrollViewer>
                </Border>

                <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="0" ClipToBounds="True">
                    <Grid>
                        <DataGrid x:Name="LessonsGrid" Style="{DynamicResource ModernDataGridStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding LessonNumber}" Width="50"/>
                                <DataGridTextColumn Header="שם השיעור" Binding="{Binding Title}" Width="*"/>
                                <DataGridTextColumn Header="רב" Binding="{Binding RabbiName}" Width="180" Visibility="Collapsed"/>
                                <DataGridTextColumn Header="תאריך" Binding="{Binding FormattedDate}" Width="100"/>
                                
                                <DataGridTemplateColumn Header="סטטוס" Width="200">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <ProgressBar Value="{Binding ProgressPercentage, Mode=OneWay}"
                                                             Maximum="100" Height="6" VerticalAlignment="Bottom"
                                                             Foreground="{Binding Status, Converter={StaticResource StatusToColor}}"
                                                             Background="{DynamicResource SearchBoxBrush}" BorderThickness="0"/>
                                                <TextBlock Text="{Binding StatusText, Mode=OneWay}"
                                                           HorizontalAlignment="Left" VerticalAlignment="Top"
                                                           FontSize="11" Margin="0,0,0,8"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="פעולה" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="הורד" Click="DownloadButton_Click"
                                                    Style="{DynamicResource SecondaryButtonStyle}"
                                                    Padding="10,4" FontSize="12"
                                                    Visibility="{Binding Status, Converter={StaticResource StatusToVisibility}}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Lessons Loading -->
                        <StackPanel x:Name="LessonsLoadingBar" Visibility="Collapsed"
                                    VerticalAlignment="Center" HorizontalAlignment="Center">
                            <ProgressBar IsIndeterminate="True" Height="4" Width="200" Foreground="{DynamicResource AccentBrush}"/>
                            <TextBlock Text="טוען שיעורים..." TextAlignment="Center" Margin="0,8,0,0" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- Status Bar -->
            <Grid Grid.Row="3" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <ProgressBar x:Name="OverallProgressBar" Height="4" Foreground="{DynamicResource AccentBrush}" Maximum="100" Value="0" Background="{DynamicResource BorderBrush}"/>
                    <TextBlock x:Name="StatusText" Text="מוכן" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,5,0,0"/>
                </StackPanel>
                
                <TextBlock x:Name="OverallProgressText" Grid.Column="1" Text="" VerticalAlignment="Bottom" Foreground="{DynamicResource TextPrimaryBrush}" Margin="10,0,0,0"/>
                
                <TextBlock x:Name="VersionText" Grid.Column="2"
                           Text="v1.1.0"
                           FontSize="10"
                           Opacity="0.4"
                           Foreground="{DynamicResource MutedTextBrush}"
                           VerticalAlignment="Bottom"
                           HorizontalAlignment="Left"
                           Margin="15,0,0,0"/>

                <Button x:Name="AboutButton" Grid.Column="3" Content="אודות" Click="AboutButton_Click"
                        VerticalAlignment="Bottom" Margin="10,0,0,0" Padding="0" Cursor="Hand"
                        ToolTip="אודות התוכנה">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <TextBlock x:Name="aboutText" Text="{TemplateBinding Content}"
                                       FontSize="10" Foreground="{DynamicResource MutedTextBrush}" Opacity="0.5"
                                       TextDecorations="Underline" Cursor="Hand"/>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="aboutText" Property="Opacity" Value="1.0"/>
                                    <Setter TargetName="aboutText" Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Grid>

        <!-- Sidebar (Right) -->
        <Border Grid.Column="1" Background="{DynamicResource CardBackgroundBrush}" Effect="{DynamicResource CardShadow}">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Tab buttons -->
                    <RowDefinition Height="Auto"/>  <!-- Search box -->
                    <RowDefinition Height="*"/>     <!-- List -->
                    <RowDefinition Height="Auto"/>  <!-- Refresh button -->
                </Grid.RowDefinitions>

                <!-- Tab Buttons: רבנים / נושאים -->
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="RabbisTabButton" Grid.Column="0" Content="רבנים"
                            Click="RabbisTabButton_Click"
                            Style="{DynamicResource ModernButtonStyle}"
                            Margin="0,0,4,0"/>
                    <Button x:Name="TopicsTabButton" Grid.Column="1" Content="נושאים"
                            Click="TopicsTabButton_Click"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Margin="4,0,0,0"/>
                </Grid>

                <!-- Search Box (rabbis only) -->
                <Border x:Name="SearchBoxBorder" Grid.Row="1" Background="{DynamicResource SearchBoxBrush}" CornerRadius="6" Padding="5" Margin="0,0,0,12">
                    <TextBox x:Name="SearchTextBox"
                             TextChanged="SearchTextBox_TextChanged"
                             Background="Transparent"
                             BorderThickness="0"
                             FontSize="14"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             CaretBrush="{DynamicResource TextPrimaryBrush}"
                             VerticalContentAlignment="Center"
                             Padding="5,0"/>
                </Border>

                <!-- Rabbis List -->
                <ListBox x:Name="RabbiListBox" Grid.Row="2"
                         SelectionChanged="RabbiListBox_SelectionChanged"
                         Background="Transparent" BorderThickness="0"
                         ItemContainerStyle="{DynamicResource RabbiListBoxItemStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="8,6" ToolTip="{Binding Name}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Avatar Image (with fallback to initials) -->
                                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20"
                                        ClipToBounds="True" Background="{DynamicResource AvatarBackgroundBrush}">
                                    <Grid>
                                        <!-- Fallback: Initial letter -->
                                        <TextBlock Text="{Binding Name, Converter={StaticResource TextToInitial}}"
                                                   FontSize="16" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <!-- Image overlay (covers initials when loaded) -->
                                        <Image Source="{Binding AvatarImage}" Stretch="UniformToFill"
                                               Width="40" Height="40"/>
                                        
                                        <!-- Loading Indicator -->
                                        <Grid Visibility="{Binding IsImageLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                                              Background="{DynamicResource OverlayBrush}">
                                            <ProgressBar IsIndeterminate="True" Width="20" Height="20"
                                                         Style="{DynamicResource MaterialDesignCircularProgressBar}"
                                                         Foreground="{DynamicResource AccentBrush}"/>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <!-- Name and count -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}">
                                        <Run Text="{Binding Count, Mode=OneWay}"/>
                                        <Run Text=" שיעורים"/>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Topics List -->
                <ListBox x:Name="TopicsListBox" Grid.Row="2"
                         Visibility="Collapsed"
                         SelectionChanged="TopicsListBox_SelectionChanged"
                         Background="Transparent" BorderThickness="0"
                         ItemContainerStyle="{DynamicResource RabbiListBoxItemStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="8,6" ToolTip="{Binding Name}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Topic icon -->
                                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20"
                                        Background="{DynamicResource AvatarBackgroundBrush}">
                                    <TextBlock Text="📚" FontSize="18"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <!-- Name and count -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}">
                                        <Run Text="{Binding Count, Mode=OneWay}"/>
                                        <Run Text=" שיעורים"/>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Rabbi/Topic Loading -->
                <StackPanel x:Name="RabbiLoadingBar" Grid.Row="2" Visibility="Collapsed"
                            VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Height="4" Width="100" Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="טוען..." TextAlignment="Center" Margin="0,8,0,0" Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>

                <Button Grid.Row="3" Content="טען מחדש" Click="RefreshButton_Click" 
                        Style="{DynamicResource SecondaryButtonStyle}" Margin="0,20,0,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
